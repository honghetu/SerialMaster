<UserControl x:Class="SerialMaster.UI.Views.FavoritesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- Favorite items list -->
        <ListView Grid.Column="0" ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  Background="{DynamicResource SecondaryBackgroundBrush}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Category}" FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Background="{DynamicResource SurfaceBrush}"
                                   Padding="4,1" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="{Binding Data}" FontSize="10" FontFamily="Consolas"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="发送" Width="50" Height="24" FontSize="11"
                                    Command="{Binding DataContext.SendCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}"
                                    Background="{DynamicResource SuccessBrush}"
                                    Foreground="{DynamicResource PrimaryBackgroundBrush}"
                                    BorderThickness="0" Margin="0,0,4,0"/>
                            <Button Content="✕" Width="28" Height="24" FontSize="11"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}"
                                    Background="{DynamicResource ErrorBrush}"
                                    Foreground="{DynamicResource PrimaryBackgroundBrush}"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Add/Edit panel -->
        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1,0,0,0" Padding="12">
            <StackPanel>
                <TextBlock Text="添加收藏" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                <TextBlock Text="名称" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,3"/>
                <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource SurfaceBorderBrush}"
                         FontSize="12" Padding="6,4" Margin="0,0,0,10"/>

                <TextBlock Text="分类" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,3"/>
                <TextBox Text="{Binding EditCategory, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource SurfaceBorderBrush}"
                         FontSize="12" Padding="6,4" Margin="0,0,0,10"/>

                <TextBlock Text="数据 (HEX)" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,3"/>
                <TextBox Text="{Binding EditData, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource HexDataBrush}"
                         BorderBrush="{DynamicResource SurfaceBorderBrush}"
                         FontFamily="Consolas" FontSize="12" Padding="6,4"
                         MinHeight="80" AcceptsReturn="True" TextWrapping="Wrap"
                         Margin="0,0,0,12"/>

                <Button Content="添加到收藏" Command="{Binding AddCommand}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource PrimaryBackgroundBrush}"
                        BorderThickness="0" Padding="8,6" FontSize="12"/>

                <Separator Background="{DynamicResource SurfaceBorderBrush}" Margin="0,16"/>

                <Button Content="清空所有收藏" Command="{Binding ClearAllCommand}"
                        Background="{DynamicResource SurfaceBrush}"
                        Foreground="{DynamicResource ErrorBrush}"
                        BorderBrush="{DynamicResource SurfaceBorderBrush}"
                        Padding="8,6" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
