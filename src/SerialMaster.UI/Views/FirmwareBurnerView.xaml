<UserControl x:Class="SerialMaster.UI.Views.FirmwareBurnerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SerialMaster.UI.Converters">
    <UserControl.Resources>
        <conv:InvertBoolConverter x:Key="InvertBool"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" Padding="14" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="🔥 固件烧录" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                <TextBlock Text="芯片家族" FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,3"/>
                <ComboBox ItemsSource="{Binding Families}"
                          SelectedItem="{Binding SelectedFamily}" Margin="0,0,0,10"/>

                <TextBlock Text="固件文件" FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,3"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding FirmwarePath, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="11"/>
                    <Button Grid.Column="1" Content="..." Width="36" Margin="4,0,0,0"
                            Command="{Binding BrowseFirmwareCommand}"/>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="端口" FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding AvailablePorts}"
                                      SelectedItem="{Binding SelectedPort}"/>
                            <Button Grid.Column="1" Content="↻" Width="28" Margin="4,0,0,0"
                                    Command="{Binding RefreshPortsCommand}"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="波特率" FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding BaudRates}"
                                  SelectedItem="{Binding BaudRate}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="可执行路径 (esptool.exe / stm32flash.exe)" FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,3"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding ExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="11"/>
                    <Button Grid.Column="1" Content="..." Width="36" Margin="4,0,0,0"
                            Command="{Binding BrowseExecutableCommand}"/>
                </Grid>

                <TextBlock Text="Flash 偏移 (字节, ESP 适用)" FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,3"/>
                <TextBox Text="{Binding FlashOffset, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas" FontSize="11" Margin="0,0,0,16"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="开始烧录" Width="100" Height="32" FontWeight="SemiBold"
                            Background="{DynamicResource SuccessBrush}"
                            Foreground="#1E1E2E"
                            BorderThickness="0"
                            Command="{Binding BurnCommand}"
                            IsEnabled="{Binding IsBurning, Converter={StaticResource InvertBool}, FallbackValue=True}"/>
                    <Button Content="取消" Width="80" Height="32" Margin="6,0,0,0"
                            Background="{DynamicResource ErrorBrush}"
                            Foreground="{DynamicResource PrimaryBackgroundBrush}"
                            BorderThickness="0"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsBurning}"/>
                </StackPanel>

                <TextBlock Margin="0,12,0,0" FontSize="10"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap">
                    <Run Text="提示: 本工具调用外部进程 (esptool / stm32flash)。请确认对应可执行文件在 PATH 中，或在「可执行路径」中提供完整路径。"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource PrimaryBackgroundBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" Padding="0" Margin="10,0,0,0" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}"
                        Padding="10,6">
                    <TextBlock Text="烧录日志" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                </Border>
                <ListBox Grid.Row="1" ItemsSource="{Binding LogLines}"
                         Background="{DynamicResource PrimaryBackgroundBrush}"
                         BorderThickness="0"
                         FontFamily="Consolas" FontSize="12"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         VirtualizingStackPanel.IsVirtualizing="True">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
