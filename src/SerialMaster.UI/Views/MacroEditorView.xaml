<UserControl x:Class="SerialMaster.UI.Views.MacroEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Step list -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" Padding="10" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="▶ 播放" Width="70" Margin="0,0,6,0"
                            Command="{Binding PlayCommand}"
                            Background="{DynamicResource SuccessBrush}"
                            Foreground="{DynamicResource PrimaryBackgroundBrush}" BorderThickness="0"/>
                    <Button Content="■ 停止" Width="70" Margin="0,0,6,0"
                            Command="{Binding StopCommand}"
                            Background="{DynamicResource ErrorBrush}"
                            Foreground="{DynamicResource PrimaryBackgroundBrush}" BorderThickness="0"/>
                    <Button Content="保存" Width="50" Margin="0,0,6,0"
                            Command="{Binding SaveCommand}"
                            Background="{DynamicResource SurfaceBrush}"
                            Foreground="{DynamicResource PrimaryTextBrush}"
                            BorderBrush="{DynamicResource SurfaceBorderBrush}"/>
                    <Button Content="加载" Width="50"
                            Command="{Binding LoadCommand}"
                            Background="{DynamicResource SurfaceBrush}"
                            Foreground="{DynamicResource PrimaryTextBrush}"
                            BorderBrush="{DynamicResource SurfaceBorderBrush}"/>
                </StackPanel>

                <ListView Grid.Row="1" ItemsSource="{Binding Steps}"
                          SelectedItem="{Binding SelectedStep}"
                          Background="{DynamicResource SecondaryBackgroundBrush}"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="3,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="3" Padding="4,2"
                                        Background="{DynamicResource AccentBrush}">
                                    <TextBlock FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryBackgroundBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="Send">
                                                        <Setter Property="Text" Value="发送"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Delay">
                                                        <Setter Property="Text" Value="延时"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="LoopStart">
                                                        <Setter Property="Text" Value="循环▶"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="LoopEnd">
                                                        <Setter Property="Text" Value="◀循环"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <TextBlock Grid.Column="1" Text="{Binding Data}" FontSize="11" FontFamily="Consolas"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Margin="6,0" VerticalAlignment="Center"
                                           MinWidth="60"/>
                                <TextBlock Grid.Column="2" FontSize="10"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="延时:"/><Run Text="{Binding DelayMs}"/><Run Text="ms"/>
                                    <Run Text=" 重复:"/><Run Text="{Binding RepeatCount}"/>
                                </TextBlock>
                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                    <Button Content="▲" Width="24" Height="20" FontSize="9"
                                            Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            BorderThickness="0" Margin="0,0,2,0"
                                            Background="{DynamicResource SurfaceBrush}"
                                            Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <Button Content="▼" Width="24" Height="20" FontSize="9"
                                            Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            BorderThickness="0" Margin="0,0,2,0"
                                            Background="{DynamicResource SurfaceBrush}"
                                            Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <Button Content="✕" Width="24" Height="20" FontSize="9"
                                            Command="{Binding DataContext.DeleteStepCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            BorderThickness="0"
                                            Background="{DynamicResource ErrorBrush}"
                                            Foreground="{DynamicResource PrimaryBackgroundBrush}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Grid.Row="2" Text="提示: 点击 ▶ 开始播放宏序列。循环需要成对的 循环▶ 和 ◀循环 标记。"
                           FontSize="10" Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap" Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <!-- Right: Add step panel -->
        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" Padding="10" Margin="8,0,0,0" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="添加步骤" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>

                <TextBlock Text="类型" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                <ComboBox SelectedIndex="{Binding NewStepType}"
                          Background="{DynamicResource SecondaryBackgroundBrush}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          BorderBrush="{DynamicResource SurfaceBorderBrush}" Margin="0,0,0,8">
                    <ComboBoxItem Content="发送数据"/>
                    <ComboBoxItem Content="延时"/>
                    <ComboBoxItem Content="循环开始"/>
                    <ComboBoxItem Content="循环结束"/>
                </ComboBox>

                <TextBlock Text="数据 (HEX)" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding NewStepData, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas" FontSize="11" Padding="4"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource HexDataBrush}"
                         BorderBrush="{DynamicResource SurfaceBorderBrush}" Margin="0,0,0,8"/>

                <TextBlock Text="延时 (ms)" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding NewStepDelay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource SurfaceBorderBrush}" Margin="0,0,0,8"/>

                <TextBlock Text="重复次数" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding NewStepRepeat, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource SurfaceBorderBrush}" Margin="0,0,0,12"/>

                <Button Content="添加步骤" Command="{Binding AddStepCommand}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource PrimaryBackgroundBrush}"
                        BorderThickness="0" Padding="8,6"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
