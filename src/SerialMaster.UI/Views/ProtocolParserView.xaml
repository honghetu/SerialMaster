<UserControl x:Class="SerialMaster.UI.Views.ProtocolParserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Protocol list -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" Padding="8" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="已保存协议" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding Definitions}"
                         SelectedItem="{Binding SelectedDefinition}"
                         DisplayMemberPath="Name"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderThickness="0"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="新建" Width="50" Command="{Binding NewDefinitionCommand}"/>
                    <Button Content="删除" Width="50" Margin="4,0,0,0"
                            Command="{Binding DeleteDefinitionCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Middle: Edit definition -->
        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" Padding="8" Margin="6,0,0,0" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="协议定义" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>

                <Grid Grid.Row="1" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="名称" VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                    <TextBox Grid.Column="1" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="帧头 HEX" VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                    <TextBox Grid.Column="1" Text="{Binding EditHeaderHex, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="例: AA 55 ；留空则不做帧头同步"/>
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="帧长 (字节)" VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                    <TextBox Grid.Column="1" Text="{Binding EditFrameLength, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="含帧头的总字节数"/>
                </Grid>

                <DataGrid Grid.Row="4" ItemsSource="{Binding Fields}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          Background="{DynamicResource SecondaryBackgroundBrush}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          RowBackground="{DynamicResource SurfaceBrush}"
                          AlternatingRowBackground="{DynamicResource SecondaryBackgroundBrush}"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="80"/>
                        <DataGridTextColumn Header="偏移" Binding="{Binding Offset}" Width="50"/>
                        <DataGridTextColumn Header="长度" Binding="{Binding Length}" Width="50"/>
                        <DataGridTextColumn Header="波形通道"
                            Binding="{Binding WaveformChannel, TargetNullValue=''}"
                            Width="70"/>
                        <DataGridComboBoxColumn Header="类型"
                            SelectedItemBinding="{Binding Type}"
                            Width="*">
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource"
                                            Value="{Binding DataContext.FieldTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource"
                                            Value="{Binding DataContext.FieldTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="+ 字段" Width="60" Command="{Binding AddFieldCommand}"/>
                    <Button Content="− 字段" Width="60" Margin="4,0,0,0"
                            Command="{Binding DeleteFieldCommand}"
                            CommandParameter="{Binding SelectedItem,
                                ElementName=FieldsGrid}"/>
                    <Button Content="保存协议" Width="80" Margin="8,0,0,0"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource PrimaryBackgroundBrush}"
                            Command="{Binding SaveDefinitionCommand}"/>
                    <Button Content="应用到会话" Width="90" Margin="4,0,0,0"
                            Background="{DynamicResource SuccessBrush}"
                            Foreground="#1E1E2E"
                            Command="{Binding ApplyToActiveSessionCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right: Parse test -->
        <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" Padding="8" Margin="6,0,0,0" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="解析测试" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>

                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding InputHex, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="12" MinHeight="36"
                             Background="{DynamicResource SecondaryBackgroundBrush}"
                             Foreground="{DynamicResource HexDataBrush}"
                             Padding="6,4" AcceptsReturn="True"/>
                    <Button Grid.Column="1" Content="解析" Width="60" Margin="8,0,0,0"
                            Command="{Binding ParseCommand}"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource PrimaryBackgroundBrush}"
                            BorderThickness="0"/>
                </Grid>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ParseResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11"
                                               FontFamily="Consolas"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
