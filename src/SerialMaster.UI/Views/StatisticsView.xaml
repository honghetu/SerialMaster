<UserControl x:Class="SerialMaster.UI.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊 实时统计" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="{Binding ConnectedPortName}" Margin="14,0,0,0"
                           VerticalAlignment="Bottom" FontSize="13"
                           Foreground="{DynamicResource AccentBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="重置计数" Padding="10,4"
                    Command="{Binding ResetAnchorsCommand}"
                    Background="{DynamicResource SurfaceBrush}"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}"/>
        </Grid>

        <TextBlock Grid.Row="0" Margin="0,42,0,0"
                   Text="{Binding StatusText}" FontSize="11" FontFamily="Consolas"
                   Foreground="{DynamicResource MutedTextBrush}"
                   HorizontalAlignment="Left"/>

        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,16">
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="运行时长" FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Text="{Binding UptimeText}" FontSize="22" FontWeight="SemiBold"
                               FontFamily="Consolas"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="接收字节" FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Text="{Binding ReceivedBytes, StringFormat='{}{0:N0}'}"
                               FontSize="22" FontWeight="SemiBold" FontFamily="Consolas"
                               Foreground="{DynamicResource SuccessBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="发送字节" FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Text="{Binding SentBytes, StringFormat='{}{0:N0}'}"
                               FontSize="22" FontWeight="SemiBold" FontFamily="Consolas"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="解析帧" FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Text="{Binding ParsedFrameCount, StringFormat='{}{0:N0}'}"
                               FontSize="22" FontWeight="SemiBold" FontFamily="Consolas"
                               Foreground="{DynamicResource HexDataBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding ActiveProtocolName}" FontSize="10"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="速率 (B/s)" FontSize="11"
                           Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,6"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="1 秒" FontSize="11"
                           HorizontalAlignment="Right" Margin="0,0,0,6"
                           Foreground="{DynamicResource MutedTextBrush}"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="10 秒平均" FontSize="11"
                           HorizontalAlignment="Right" Margin="0,0,0,6"
                           Foreground="{DynamicResource MutedTextBrush}"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="60 秒平均" FontSize="11"
                           HorizontalAlignment="Right" Margin="0,0,0,6"
                           Foreground="{DynamicResource MutedTextBrush}"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="峰值" FontSize="11"
                           HorizontalAlignment="Right" Margin="0,0,0,6"
                           Foreground="{DynamicResource MutedTextBrush}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="↓ Rx" FontFamily="Consolas"
                           FontSize="13" Foreground="{DynamicResource SuccessBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RxRate1s, StringFormat='{}{0:N0}'}"
                           HorizontalAlignment="Right" FontFamily="Consolas" FontSize="13"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding RxRate10s, StringFormat='{}{0:N0}'}"
                           HorizontalAlignment="Right" FontFamily="Consolas" FontSize="13"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding RxRate60s, StringFormat='{}{0:N0}'}"
                           HorizontalAlignment="Right" FontFamily="Consolas" FontSize="13"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding PeakRxRate, StringFormat='{}{0:N0}'}"
                           HorizontalAlignment="Right" FontFamily="Consolas" FontSize="13"
                           Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="↑ Tx" FontFamily="Consolas"
                           FontSize="13" Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding TxRate1s, StringFormat='{}{0:N0}'}"
                           HorizontalAlignment="Right" FontFamily="Consolas" FontSize="13"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Grid.Column="2" Text="{Binding TxRate10s, StringFormat='{}{0:N0}'}"
                           HorizontalAlignment="Right" FontFamily="Consolas" FontSize="13"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Grid.Column="3" Text="{Binding TxRate60s, StringFormat='{}{0:N0}'}"
                           HorizontalAlignment="Right" FontFamily="Consolas" FontSize="13"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Grid.Column="4" Text="{Binding PeakTxRate, StringFormat='{}{0:N0}'}"
                           HorizontalAlignment="Right" FontFamily="Consolas" FontSize="13"
                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" CornerRadius="6" Padding="14">
            <StackPanel>
                <TextBlock Text="错误计数" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="{DynamicResource ErrorBrush}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="失败发送" Margin="8,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding ErrorCount}" Margin="14,0,0,0"
                                   FontFamily="Consolas" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ErrorBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="{DynamicResource WarningBrush}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="超时" Margin="8,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding WarningCount}" Margin="14,0,0,0"
                                   FontFamily="Consolas" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
